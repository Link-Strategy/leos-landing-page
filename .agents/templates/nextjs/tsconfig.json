{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "components/*": [
        "./components/*",
        "../../components/*"
      ],
      "@/components/ui/*": [
        "./components/ui/*",
        "../../../components/ui/react/*"
      ],
      "@/components/business/*": [
        "./src/components/business/*"
      ],
      "@/components/*": [
        "./components/*",
        "../../components/*"
      ],
      "@contracts/*": [
        "assets/contracts/generated/typescript/*",
        "../../assets/contracts/generated/typescript/*"
      ],
      "@configs/*": [
        "assets/configs/generated/typescript/*",
        "../../assets/configs/generated/typescript/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.json",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
