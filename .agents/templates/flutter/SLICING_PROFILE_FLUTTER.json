{
  "name": "Flutter Flat Slicing Profile Template",
  "version": "3.1.0",
  "description": "Standardized Flat Architecture for Flutter. Supports Contract/UI resolution via path normalization.",
  "provisioning": {
    "organization": "Link-Strategy",
    "delivery_policy": {
      "allow_baseline": [
        "README.md",
        "GEMINI.md",
        "01_TASK_SPEC.md",
        "02_DECISION_LOGS.md",
        "03_LOGS.md",
        "package.json",
        "package-lock.json",
        "pubspec.yaml",
        "pubspec.lock",
        "analysis_options.yaml",
        ".metadata",
        ".gitignore",
        "slicing-profile.json",
        "lib/",
        "test/",
        "assets/",
        "fonts/",
        "linux/",
        "web/",
        "android/",
        "ios/",
        "scripts/"
      ],
      "deny_prefixes": [
        ".git/",
        ".agents/",
        ".github/workflows/",
        "node_modules/",
        "dist/",
        "build/",
        ".dart_tool/"
      ]
    }
  },
  "packaging": {
    "templates": [
      {
        "src": "01_TASK_SPEC_TEMPLATE.md",
        "dest": "01_TASK_SPEC.md"
      },
      {
        "src": "02_DECISION_LOGS_TEMPLATE.md",
        "dest": "02_DECISION_LOGS.md"
      },
      {
        "src": "03_LOGS_TEMPLATE.md",
        "dest": "03_LOGS.md"
      },
      {
        "src": "flutter/SLICING_PROFILE_FLUTTER.json",
        "dest": "slicing-profile.json"
      },
      {
        "src": "flutter/pubspec_overrides.yaml",
        "dest": "pubspec_overrides.yaml"
      }
    ]
  },
  "mappings": [
    {
      "id": "hands-rules",
      "type": "Rule",
      "source": ".agents/rules/hands/",
      "target": ".agents/rules/",
      "description": "Luật thực thi dành cho Hands"
    },
    {
      "id": "hands-workflows",
      "type": "Workflow",
      "source": ".agents/workflows/hands/",
      "target": ".agents/workflows/",
      "description": "Workflow dành cho Hands"
    },
    {
      "id": "hands-skills",
      "type": "Skill",
      "source": ".agents/skills/hands/",
      "target": ".agents/skills/",
      "description": "Kỹ năng thực thi dành cho thợ"
    },
    {
      "id": "satellite-constitution",
      "type": "Rule",
      "source": ".agents/templates/GEMINI_SATELLITE_TEMPLATE.md",
      "target": "GEMINI.md",
      "description": "Hiến pháp Vệ tinh"
    },
    {
      "id": "ls-engine",
      "type": "Tool",
      "source": ".agents/tools/ls-engine/",
      "target": ".agents/tools/ls-engine/",
      "description": "Bộ máy vận hành Link Strategy"
    },
    {
      "id": "ls-ci-cd",
      "type": "Tool",
      "source": ".agents/templates/link-strategy-hands.yml",
      "target": ".github/workflows/link-strategy-hands.yml",
      "description": "Chốt chặn CI/CD tự động (Guardian Mode)"
    },
    {
      "id": "sovereign-contracts",
      "type": "DNA",
      "source": "assets/contracts/",
      "target": "assets/contracts/",
      "description": "JSON Schemas and Generated Data Models"
    },
    {
      "id": "sovereign-configs",
      "type": "DNA",
      "source": "assets/configs/",
      "target": "assets/configs/",
      "description": "Unified Matrix Configurations and Generated Adapters"
    },
    {
      "id": "shared-ui-dart",
      "type": "Shell",
      "source": "components/ui/dart/",
      "target": "components/ui/dart/",
      "description": "Shared Flutter UI package from Brain"
    },
    {
      "id": "lib-baseline",
      "type": "Shell",
      "source": "{{SERVICE_PATH}}/lib/",
      "target": "lib/",
      "description": "Mã nguồn logic ứng dụng"
    },
    {
      "id": "test-baseline",
      "type": "Shell",
      "source": "{{SERVICE_PATH}}/test/",
      "target": "test/",
      "description": "Mã nguồn kiểm thử"
    },
    {
      "id": "linux-infra",
      "type": "Shell",
      "source": "{{SERVICE_PATH}}/linux/",
      "target": "linux/",
      "description": "Linux Native Infrastructure"
    },
    {
      "id": "web-infra",
      "type": "Shell",
      "source": "{{SERVICE_PATH}}/web/",
      "target": "web/",
      "description": "Web Native Infrastructure"
    },
    {
      "id": "android-infra",
      "type": "Shell",
      "source": "{{SERVICE_PATH}}/android/",
      "target": "android/",
      "description": "Android Native Infrastructure"
    },
    {
      "id": "ios-infra",
      "type": "Shell",
      "source": "{{SERVICE_PATH}}/ios/",
      "target": "ios/",
      "description": "iOS Native Infrastructure"
    },
    {
      "id": "task-spec",
      "type": "Task",
      "source": "{{SERVICE_PATH}}/01_TASK_SPEC.md",
      "target": "01_TASK_SPEC.md",
      "description": "Đặc tả nhiệm vụ"
    },
    {
      "id": "pubspec-dna",
      "type": "DNA",
      "source": "{{SERVICE_PATH}}/pubspec.yaml",
      "target": "pubspec.yaml",
      "description": "Flutter Pubspec DNA"
    },
    {
      "id": "lock-dna",
      "type": "DNA",
      "source": "{{SERVICE_PATH}}/pubspec.lock",
      "target": "pubspec.lock",
      "description": "Flutter Lockfile DNA"
    },
    {
      "id": "lint-dna",
      "type": "DNA",
      "source": "{{SERVICE_PATH}}/analysis_options.yaml",
      "target": "analysis_options.yaml",
      "description": "Flutter Lint DNA"
    },
    {
      "id": "metadata-dna",
      "type": "DNA",
      "source": "{{SERVICE_PATH}}/.metadata",
      "target": ".metadata",
      "description": "Flutter Metadata DNA"
    },
    {
      "id": "package-dna",
      "type": "DNA",
      "source": "{{SERVICE_PATH}}/package.json",
      "target": "package.json",
      "description": "Workspace scripts DNA"
    },
    {
      "id": "package-lock-dna",
      "type": "DNA",
      "source": "{{SERVICE_PATH}}/package-lock.json",
      "target": "package-lock.json",
      "description": "Standalone Satellite Node tooling lockfile"
    },
    {
      "id": "gitignore-dna",
      "type": "DNA",
      "source": "{{SERVICE_PATH}}/.gitignore",
      "target": ".gitignore",
      "description": "Flutter Ignore DNA"
    },
    {
      "id": "app-scripts",
      "type": "Shell",
      "source": "{{SERVICE_PATH}}/scripts/",
      "target": "scripts/",
      "description": "Application scripts"
    },
    {
      "id": "slicing-profile-dna",
      "type": "DNA",
      "source": "{{SERVICE_PATH}}/slicing-profile.json",
      "target": "slicing-profile.json",
      "description": "Slicing Profile"
    }
  ],
  "harvesting": [
    {
      "id": "decision-logs",
      "type": "Task",
      "source": "02_DECISION_LOGS.md",
      "target": "{{SERVICE_PATH}}/02_DECISION_LOGS.md",
      "description": "Nhật ký quyết định"
    },
    {
      "id": "implementation-logs",
      "type": "Task",
      "source": "03_LOGS.md",
      "target": "{{SERVICE_PATH}}/03_LOGS.md",
      "description": "Nhật ký tiến độ"
    },
    {
      "id": "harvest-lib",
      "type": "Shell",
      "source": "lib/",
      "target": "{{SERVICE_PATH}}/lib/",
      "description": "Thu hoạch mã nguồn logic"
    },
    {
      "id": "harvest-test",
      "type": "Shell",
      "source": "test/",
      "target": "{{SERVICE_PATH}}/test/",
      "description": "Thu hoạch mã nguồn test"
    },
    {
      "id": "harvest-linux",
      "type": "Shell",
      "source": "linux/",
      "target": "{{SERVICE_PATH}}/linux/",
      "description": "Thu hoạch mã nguồn native Linux"
    },
    {
      "id": "harvest-pubspec",
      "type": "DNA",
      "source": "pubspec.yaml",
      "target": "{{SERVICE_PATH}}/pubspec.yaml",
      "description": "Thu hoạch cấu hình dependency"
    },
    {
      "id": "harvest-package-lock",
      "type": "DNA",
      "source": "package-lock.json",
      "target": "{{SERVICE_PATH}}/package-lock.json",
      "description": "Thu hoạch Node tooling lockfile"
    },
    {
      "id": "harvest-lint",
      "type": "DNA",
      "source": "analysis_options.yaml",
      "target": "{{SERVICE_PATH}}/analysis_options.yaml",
      "description": "Thu hoạch quy tắc lint"
    },
    {
      "id": "gate-reports",
      "type": "Task",
      "source": "report/",
      "target": "{{SERVICE_PATH}}/report/",
      "description": "Bằng chứng nghiệm thu"
    },
    {
      "id": "harvest-scripts",
      "type": "Shell",
      "source": "scripts/",
      "target": "{{SERVICE_PATH}}/scripts/",
      "description": "Thu hoạch script ứng dụng"
    }
  ]
}
